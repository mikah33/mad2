                      <h4 key={i} className="font-semibold text-gray-800 mt-3 first:mt-0">{item}</h4>
                    );
                  }
                  // Description text (no bullet)
                  if (!item.startsWith('•')) {
                    return (
                      <p key={i} className="text-sm text-gray-600">{item}</p>
                    );
                  }
                  // Bullet items
                  return (
                    <p key={i} className="text-sm text-gray-600 pl-2">{item}</p>
